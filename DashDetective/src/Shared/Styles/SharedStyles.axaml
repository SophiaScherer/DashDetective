<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
      Reusable styling for DashDetective. Applied app-wide via a class name
      (e.g. <Border Classes="panel"/>). Tabs and widgets share these so the look
      stays consistent and is defined once.
    -->

    <!-- ===== Surfaces ===== -->
    <Style Selector="Border.panel">
        <Setter Property="Background" Value="{StaticResource PanelBackground}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Hairline}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="9"/>
        <Setter Property="Padding" Value="16"/>
    </Style>
    <Style Selector="Border.card">
        <Setter Property="Background" Value="{StaticResource CardBackground}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Hairline}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="9"/>
        <Setter Property="Padding" Value="13,12"/>
    </Style>

    <!-- ===== Typography ===== -->
    <Style Selector="TextBlock.panelTitle">
        <Setter Property="FontSize" Value="13.5"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style Selector="TextBlock.cardLabel">
        <Setter Property="FontSize" Value="11.5"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
    </Style>
    <Style Selector="TextBlock.cardValue">
        <Setter Property="FontSize" Value="26"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
    </Style>
    <Style Selector="TextBlock.cardUnit">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
    </Style>
    <Style Selector="TextBlock.cardSub">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="{StaticResource TextSubtle}"/>
    </Style>

    <!-- ===== Key/value rows (used by the InfoRow widget) ===== -->
    <Style Selector="Border.infoRow">
        <Setter Property="BorderBrush" Value="{StaticResource RowLine}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Padding" Value="0,7"/>
    </Style>
    <Style Selector="Border.infoRow TextBlock.infoKey">
        <Setter Property="FontSize" Value="12.5"/>
        <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
    </Style>
    <Style Selector="Border.infoRow TextBlock.infoVal">
        <Setter Property="FontSize" Value="12.5"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
        <Setter Property="TextAlignment" Value="Right"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <!-- ===== Segmented selector ===== -->
    <Style Selector="Border.segments">
        <Setter Property="Background" Value="{StaticResource FieldBackground}"/>
        <Setter Property="CornerRadius" Value="7"/>
        <Setter Property="Padding" Value="3"/>
    </Style>
    <Style Selector="Border.seg">
        <Setter Property="CornerRadius" Value="5"/>
        <Setter Property="Padding" Value="14,6"/>
    </Style>
    <Style Selector="Border.seg.selected">
        <Setter Property="Background" Value="{StaticResource Accent}"/>
    </Style>
    <Style Selector="Border.seg TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
    </Style>
    <Style Selector="Border.seg.selected TextBlock">
        <Setter Property="Foreground" Value="{StaticResource OnAccent}"/>
    </Style>

    <!-- ===== Pill toggle track ===== -->
    <Style Selector="Border.toggle">
        <Setter Property="Width" Value="40"/>
        <Setter Property="Height" Value="22"/>
        <Setter Property="CornerRadius" Value="11"/>
    </Style>

    <!-- ===== Action buttons ===== -->
    <Style Selector="Button.action">
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="16,9"/>
        <Setter Property="FontSize" Value="12.5"/>
        <Setter Property="Background" Value="#12FFFFFF"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.action:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#1FFFFFFF"/>
    </Style>
    <Style Selector="Button.primary">
        <Setter Property="Background" Value="{StaticResource Accent}"/>
        <Setter Property="Foreground" Value="{StaticResource OnAccent}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style Selector="Button.primary:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{StaticResource AccentHover}"/>
    </Style>
</Styles>
