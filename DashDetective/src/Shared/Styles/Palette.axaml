<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
      Central colour palette for DashDetective. Every view/widget references these
      keys instead of hardcoding hex values, so the theme can change in one place.
    -->

    <!-- Accents & series colours -->
    <SolidColorBrush x:Key="Accent" Color="#4cc2ff"/>
    <SolidColorBrush x:Key="AccentHover" Color="#66d0ff"/>
    <SolidColorBrush x:Key="OnAccent" Color="#06263a"/>
    <SolidColorBrush x:Key="Purple" Color="#c58fff"/>
    <SolidColorBrush x:Key="Green" Color="#6ccb5f"/>
    <SolidColorBrush x:Key="Yellow" Color="#ffcf4d"/>
    <SolidColorBrush x:Key="Orange" Color="#ff8a5c"/>

    <!-- Surfaces -->
    <SolidColorBrush x:Key="AppBackground" Color="#141414"/>
    <SolidColorBrush x:Key="SidebarBackground" Color="#1b1b1b"/>
    <SolidColorBrush x:Key="PanelBackground" Color="#1c1c1c"/>
    <SolidColorBrush x:Key="CardBackground" Color="#212121"/>
    <SolidColorBrush x:Key="FieldBackground" Color="#141414"/>

    <!-- Lines & tracks -->
    <SolidColorBrush x:Key="Hairline" Color="#FFFFFF" Opacity="0.06"/>
    <SolidColorBrush x:Key="RowLine" Color="#FFFFFF" Opacity="0.05"/>
    <SolidColorBrush x:Key="TrackOff" Color="#FFFFFF" Opacity="0.16"/>

    <!-- Text (decreasing emphasis) -->
    <SolidColorBrush x:Key="TextStrong" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF" Opacity="0.90"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#FFFFFF" Opacity="0.72"/>
    <SolidColorBrush x:Key="TextTertiary" Color="#FFFFFF" Opacity="0.62"/>
    <SolidColorBrush x:Key="TextMuted" Color="#FFFFFF" Opacity="0.50"/>
    <SolidColorBrush x:Key="TextSubtle" Color="#FFFFFF" Opacity="0.45"/>
    <SolidColorBrush x:Key="TextFaint" Color="#FFFFFF" Opacity="0.35"/>
</ResourceDictionary>
