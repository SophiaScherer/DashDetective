<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DashDetective.Shell"
        xmlns:nav="using:DashDetective.Shell.Navigation"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1180" d:DesignHeight="760"
        x:Class="DashDetective.Shell.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="DashDetective"
        Width="1180" Height="760"
        MinWidth="920" MinHeight="560"
        Background="{DynamicResource AppBackground}"
        TransparencyLevelHint="None">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <!-- Shell-only chrome. Shared brushes/styles come from App.axaml (src/Shared/Styles).
             The sidebar nav-row styles now live with the NavigationView component. -->
        <!-- Small square icon buttons in the toolbar. -->
        <Style Selector="Button.toolIcon">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.toolIcon:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource HoverOverlay}"/>
        </Style>

        <!-- The Live status pill (toggles pause/resume of live sampling). -->
        <Style Selector="Button.livePill">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Hairline}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="11,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.livePill:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource HoverOverlay}"/>
        </Style>
    </Window.Styles>

    <DockPanel LastChildFill="True">

        <!-- ================= SIDEBAR ================= -->
        <!-- The nav bar is a self-contained component; it docks to the edge it chooses and the
             main area (the last child) fills the remaining space. -->
        <nav:NavigationView DataContext="{Binding Nav}" DockPanel.Dock="{Binding Dock}"/>

        <!-- ================= MAIN ================= -->
        <Grid RowDefinitions="54,Auto,*">

            <!-- Toolbar -->
            <Border Grid.Row="0" Background="{DynamicResource SidebarBackground}"
                    BorderBrush="{DynamicResource Hairline}" BorderThickness="0,0,0,1">
                <Grid ColumnDefinitions="Auto,*,Auto" Margin="18,0">

                    <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Nav.SelectedNav.Title}" FontSize="15" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Nav.SelectedNav.Subtitle}" FontSize="11"
                                   Foreground="{DynamicResource TextSubtle}"/>
                    </StackPanel>

                    <!-- Search -->
                    <Border Grid.Column="1" MaxWidth="420" Height="34" Margin="16,0"
                            HorizontalAlignment="Right" Background="{DynamicResource FieldBackground}"
                            BorderBrush="{DynamicResource Hairline}" BorderThickness="1" CornerRadius="6">
                        <Grid ColumnDefinitions="Auto,*" Margin="11,0">
                            <Path Grid.Column="0" Width="14" Height="14" Stretch="Uniform"
                                  Stroke="{DynamicResource TextTertiary}" StrokeThickness="1.4"
                                  StrokeLineCap="Round" VerticalAlignment="Center"
                                  Data="M7,7 m-4.5,0 a4.5,4.5 0 1 0 9,0 a4.5,4.5 0 1 0 -9,0 M10.5,10.5 L14,14"/>
                            <TextBox Grid.Column="1" Margin="9,0,0,0" BorderThickness="0"
                                     Background="Transparent" FontSize="13" VerticalContentAlignment="Center"
                                     PlaceholderText="Search processes, files, settings…"/>
                        </Grid>
                    </Border>

                    <!-- Actions -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <Button Classes="livePill" Command="{Binding ToggleLiveCommand}"
                                ToolTip.Tip="Pause or resume live updates">
                            <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                                <Ellipse Width="8" Height="8" Fill="{Binding LiveDotBrush}"/>
                                <TextBlock Text="{Binding LiveLabel}" FontSize="12"
                                           Foreground="{DynamicResource TextTertiary}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Classes="toolIcon" ToolTip.Tip="Refresh" Command="{Binding RefreshCommand}">
                            <Path Width="16" Height="16" Stretch="Uniform" Stroke="{DynamicResource TextTertiary}"
                                  StrokeThickness="1.5" StrokeLineCap="Round" StrokeJoin="Round"
                                  Data="M13,8 a5,5 0 1 1 -1.5,-3.5 M13,2.5 V5 H10.5"/>
                        </Button>
                        <Button Classes="toolIcon" ToolTip.Tip="Export" Click="OnExportClick">
                            <Path Width="16" Height="16" Stretch="Uniform" Stroke="{DynamicResource TextTertiary}"
                                  StrokeThickness="1.5" StrokeLineCap="Round" StrokeJoin="Round"
                                  Data="M8,2 V10 M8,10 L5,7 M8,10 L11,7 M3,12 V13.5 H13 V12"/>
                        </Button>
                        <Rectangle Width="1" Height="22" Fill="{DynamicResource Hairline}" Margin="3,0"/>
                        <!-- Fixed width so the proportional-font HH:mm:ss (digit widths differ as it
                             ticks) reserves constant space and never reflows the toolbar. -->
                        <TextBlock Text="{Binding Clock}" FontSize="12" Foreground="{DynamicResource TextTertiary}"
                                   VerticalAlignment="Center" Width="58" TextAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Resource-alert banner: shown when CPU/memory stays above the threshold and the user's
                 "Resource alerts" setting is on. Auto-clears on recovery; the × dismisses the current
                 breach. Fixed amber so it reads as a warning in both themes. -->
            <Border Grid.Row="1" IsVisible="{Binding AlertBannerVisible}"
                    Background="#26E0A82E" BorderBrush="#59E0A82E" BorderThickness="0,0,0,1" Padding="18,9">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <Path Grid.Column="0" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"
                          Fill="#E0A82E" Data="M8,1 L15,14 H1 Z"/>
                    <TextBlock Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center" FontSize="12.5"
                               Foreground="{DynamicResource TextPrimary}" Text="{Binding AlertText}"/>
                    <Button Grid.Column="2" Classes="toolIcon" Width="26" Height="26"
                            ToolTip.Tip="Dismiss" Command="{Binding DismissAlertCommand}">
                        <Path Width="11" Height="11" Stretch="Uniform" Stroke="{DynamicResource TextTertiary}"
                              StrokeThickness="1.5" StrokeLineCap="Round" Data="M1,1 L11,11 M11,1 L1,11"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Page content: normal pages get an outer scroll region; self-scrolling pages
                 (File Explorer) get a bounded, non-scrolling host so their panes scroll on their own.
                 Content is routed so only the active host is populated (view built once). -->
            <Panel Grid.Row="2" Background="{DynamicResource AppBackground}">
                <!-- Padding lives on the inner content (as Margin), not the ScrollViewer: Avalonia's
                     ScrollViewer does not include its own Padding in the scroll extent, so a bottom
                     Padding here would make the last chunk of a long page unreachable. -->
                <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto"
                              IsVisible="{Binding !CurrentPageSelfScrolls}">
                    <ContentControl Margin="22,20,22,30" Content="{Binding ScrollingPage}"/>
                </ScrollViewer>
                <ContentControl Margin="22,20,22,30"
                                Content="{Binding SelfScrollingPage}"
                                IsVisible="{Binding CurrentPageSelfScrolls}"/>
            </Panel>
        </Grid>
    </DockPanel>
</Window>
