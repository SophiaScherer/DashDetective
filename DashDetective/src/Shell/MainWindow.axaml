<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DashDetective.Shell"
        xmlns:nav="using:DashDetective.Shell.Navigation"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1180" d:DesignHeight="760"
        x:Class="DashDetective.Shell.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="DashDetective"
        Width="1180" Height="760"
        MinWidth="920" MinHeight="560"
        Background="#141414"
        TransparencyLevelHint="None">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <!-- Shell-only chrome. Shared brushes/styles come from App.axaml (src/Shared/Styles). -->
        <!-- Strip default button chrome for the sidebar nav rows. -->
        <Style Selector="Button.nav">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.nav /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!-- Small square icon buttons in the toolbar. -->
        <Style Selector="Button.toolIcon">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.toolIcon:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#12FFFFFF"/>
        </Style>

        <!-- The Live status pill (toggles pause/resume of live sampling). -->
        <Style Selector="Button.livePill">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource Hairline}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="11,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.livePill:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#12FFFFFF"/>
        </Style>
    </Window.Styles>

    <Grid ColumnDefinitions="236,*">

        <!-- ================= SIDEBAR ================= -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBackground}"
                BorderBrush="{StaticResource Hairline}" BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto,*,Auto">

                <!-- Brand -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="11"
                            Margin="18,16,18,14" VerticalAlignment="Center">
                    <Border Width="30" Height="30" CornerRadius="7">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                <GradientStop Offset="0" Color="#4cc2ff"/>
                                <GradientStop Offset="1" Color="#2a7fd4"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Viewbox Width="16" Height="16">
                            <Path Fill="White"
                                  Data="M2,2 H8 V8 H2 Z M10,2 H16 V8 H10 Z M2,10 H8 V16 H2 Z M10,10 H16 V16 H10 Z"/>
                        </Viewbox>
                    </Border>
                    <StackPanel Spacing="1" VerticalAlignment="Center">
                        <TextBlock Text="System Console" FontSize="13.5" FontWeight="SemiBold"/>
                        <TextBlock Text="Information Suite" FontSize="11" Foreground="{StaticResource TextSubtle}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Navigation -->
                <ScrollViewer Grid.Row="1" Padding="12,4" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding NavItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="nav:NavItem">
                                <Button Classes="nav" Command="{Binding SelectCommand}">
                                    <Border Background="{Binding RowBackground}" CornerRadius="6"
                                            Padding="11,9">
                                        <Grid ColumnDefinitions="3,9,18,12,*" VerticalAlignment="Center">
                                            <Rectangle Grid.Column="0" Width="3" RadiusX="1.5" RadiusY="1.5"
                                                       Height="{Binding IndicatorHeight}" Fill="{StaticResource Accent}"
                                                       HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                            <Path Grid.Column="2" Width="18" Height="18" Stretch="None"
                                                  Data="{Binding Icon}" Stroke="{Binding IconBrush}"
                                                  StrokeThickness="1.4" StrokeLineCap="Round"
                                                  StrokeJoin="Round" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="4" Text="{Binding Label}" FontSize="13"
                                                       Foreground="{Binding TextForeground}"
                                                       FontWeight="{Binding LabelWeight}"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- User footer -->
                <Border Grid.Row="2" Padding="14,12" BorderBrush="{StaticResource Hairline}"
                        BorderThickness="0,1,0,0">
                    <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                        <Border Grid.Column="0" Width="32" Height="32" CornerRadius="16">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                    <GradientStop Offset="0" Color="#6ccb5f"/>
                                    <GradientStop Offset="1" Color="#3f9c8f"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="AM" FontSize="12.5" FontWeight="SemiBold" Foreground="#0e0e0e"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="1" Margin="10,0" VerticalAlignment="Center">
                            <TextBlock Text="Alex Mercer" FontSize="12.5" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="Administrator" FontSize="10.5" Foreground="{StaticResource TextSubtle}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                            <Ellipse Width="7" Height="7" Fill="#6ccb5f"/>
                            <TextBlock Text="Online" FontSize="10.5" Foreground="#6ccb5f"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ================= MAIN ================= -->
        <Grid Grid.Column="1" RowDefinitions="54,*">

            <!-- Toolbar -->
            <Border Grid.Row="0" Background="{StaticResource SidebarBackground}"
                    BorderBrush="{StaticResource Hairline}" BorderThickness="0,0,0,1">
                <Grid ColumnDefinitions="Auto,*,Auto" Margin="18,0">

                    <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding SelectedNav.Title}" FontSize="15" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding SelectedNav.Subtitle}" FontSize="11"
                                   Foreground="{StaticResource TextSubtle}"/>
                    </StackPanel>

                    <!-- Search -->
                    <Border Grid.Column="1" MaxWidth="420" Height="34" Margin="16,0"
                            HorizontalAlignment="Right" Background="{StaticResource FieldBackground}"
                            BorderBrush="{StaticResource Hairline}" BorderThickness="1" CornerRadius="6">
                        <Grid ColumnDefinitions="Auto,*" Margin="11,0">
                            <Path Grid.Column="0" Width="14" Height="14" Stretch="Uniform"
                                  Stroke="{StaticResource TextTertiary}" StrokeThickness="1.4"
                                  StrokeLineCap="Round" VerticalAlignment="Center"
                                  Data="M7,7 m-4.5,0 a4.5,4.5 0 1 0 9,0 a4.5,4.5 0 1 0 -9,0 M10.5,10.5 L14,14"/>
                            <TextBox Grid.Column="1" Margin="9,0,0,0" BorderThickness="0"
                                     Background="Transparent" FontSize="13" VerticalContentAlignment="Center"
                                     PlaceholderText="Search processes, files, settings…"/>
                        </Grid>
                    </Border>

                    <!-- Actions -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <Button Classes="livePill" Command="{Binding ToggleLiveCommand}"
                                ToolTip.Tip="Pause or resume live updates">
                            <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                                <Ellipse Width="8" Height="8" Fill="{Binding LiveDotBrush}"/>
                                <TextBlock Text="{Binding LiveLabel}" FontSize="12"
                                           Foreground="{StaticResource TextTertiary}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Classes="toolIcon" ToolTip.Tip="Refresh" Command="{Binding RefreshCommand}">
                            <Path Width="16" Height="16" Stretch="Uniform" Stroke="{StaticResource TextTertiary}"
                                  StrokeThickness="1.5" StrokeLineCap="Round" StrokeJoin="Round"
                                  Data="M13,8 a5,5 0 1 1 -1.5,-3.5 M13,2.5 V5 H10.5"/>
                        </Button>
                        <Button Classes="toolIcon" ToolTip.Tip="Export" Click="OnExportClick">
                            <Path Width="16" Height="16" Stretch="Uniform" Stroke="{StaticResource TextTertiary}"
                                  StrokeThickness="1.5" StrokeLineCap="Round" StrokeJoin="Round"
                                  Data="M8,2 V10 M8,10 L5,7 M8,10 L11,7 M3,12 V13.5 H13 V12"/>
                        </Button>
                        <Rectangle Width="1" Height="22" Fill="{StaticResource Hairline}" Margin="3,0"/>
                        <TextBlock Text="{Binding Clock}" FontSize="12" Foreground="{StaticResource TextTertiary}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Page content -->
            <ScrollViewer Grid.Row="1" Background="{StaticResource AppBackground}" Padding="22,20,22,30">
                <ContentControl Content="{Binding CurrentPage}"/>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
