<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="using:DashDetective.Shared.Controls"
             xmlns:vm="using:DashDetective.Tabs.Dashboard"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="920"
             x:DataType="vm:DashboardViewModel"
             x:Class="DashDetective.Tabs.Dashboard.DashboardView">

    <!-- Layout only: static sample data. Surfaces/typography come from src/Shared/Styles;
         StatCard / Sparkline / InfoRow come from src/Shared/Controls. -->
    <StackPanel Spacing="16">

        <!-- ===== Stat cards ===== -->
        <Grid ColumnDefinitions="*,*,*,*,*" ColumnSpacing="12">
            <controls:StatCard Grid.Column="0" Label="CPU" Value="{Binding CpuValueText}" Unit="%"
                               Sub="{Binding CpuModelShort}" Accent="{StaticResource Accent}"
                               YMin="0" YMax="100" Points="{Binding CpuPoints}"/>
            <controls:StatCard Grid.Column="1" Label="MEMORY" Value="{Binding MemoryValueText}" Unit="GB"
                               Sub="{Binding MemorySubText}" Accent="{StaticResource Purple}"
                               YMin="0" YMax="100" Points="{Binding MemoryPoints}"/>
            <controls:StatCard Grid.Column="2" Label="GPU" Value="{Binding GpuValueText}" Unit="%"
                               Sub="{Binding GpuModelShort}" Accent="{StaticResource Green}"
                               YMin="0" YMax="100" Points="{Binding GpuPoints}"/>
            <controls:StatCard Grid.Column="3" Label="STORAGE" Value="{Binding StorageValueText}" Unit="ms"
                               Sub="{Binding StorageSubText}" Accent="{StaticResource Yellow}"
                               YMin="0" YMax="100" Points="{Binding StoragePoints}"/>
            <controls:StatCard Grid.Column="4" Label="NETWORK" Value="31" Unit="Mbps"
                               Sub="↑ 12 Mbps" Accent="{StaticResource Accent}"
                               Points="0,20 5,15 10,23 15,12 20,19 25,9 30,16 35,7 40,14 45,18 50,10 55,17 60,6 65,15 70,11 75,19 80,8 85,14 90,17 95,10 100,13"/>
        </Grid>

        <!-- ===== Utilization charts ===== -->
        <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
            <Border Grid.Column="0" Classes="panel">
                <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Classes="panelTitle" Text="CPU Utilization"/>
                        <TextBlock Grid.Column="1" Text="{Binding CpuPercentText}" FontSize="12" Foreground="{StaticResource Accent}"/>
                    </Grid>
                    <controls:Sparkline Height="130" Stroke="{StaticResource Accent}"
                                        YMin="0" YMax="100" Points="{Binding CpuPoints}"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Classes="panel">
                <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Classes="panelTitle" Text="Memory Utilization"/>
                        <TextBlock Grid.Column="1" Text="{Binding MemoryUtilizationText}" FontSize="12" Foreground="{StaticResource Purple}"/>
                    </Grid>
                    <controls:Sparkline Height="130" Stroke="{StaticResource Purple}"
                                        YMin="0" YMax="100" Points="{Binding MemoryPoints}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===== System info + Network throughput ===== -->
        <Grid ColumnDefinitions="1.35*,*" ColumnSpacing="16">

            <Border Grid.Column="0" Classes="panel">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Classes="panelTitle" Text="System Information"/>
                        <TextBlock Grid.Column="1" Text="Updated 2 min ago" FontSize="11" Foreground="{StaticResource TextSubtle}"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="24">
                        <StackPanel Grid.Column="0">
                            <controls:InfoRow Key="OS" Value="Windows 11 Pro 24H2"/>
                            <controls:InfoRow Key="Device" Value="WORKSTATION-A9"/>
                            <controls:InfoRow Key="Cores" Value="{Binding CpuCoresText}"/>
                            <controls:InfoRow Key="GPU" Value="{Binding GpuModelText}"/>
                            <controls:InfoRow Key="BIOS" Value="AMI F31d"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <controls:InfoRow Key="Build" Value="26100.1150"/>
                            <controls:InfoRow Key="CPU" Value="{Binding CpuModelText}"/>
                            <controls:InfoRow Key="RAM" Value="{Binding MemoryModelText}"/>
                            <controls:InfoRow Key="Uptime" Value="3d 14h 22m"/>
                            <controls:InfoRow Key="Motherboard" Value="ROG Z790-E"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Classes="panel">
                <StackPanel Spacing="12">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Classes="panelTitle" Text="Network Throughput"/>
                        <TextBlock Grid.Column="1" Text="Ethernet" FontSize="11" Foreground="{StaticResource TextSubtle}"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <StackPanel Spacing="1">
                            <TextBlock Text="↓ Download" FontSize="11" Foreground="{StaticResource TextMuted}"/>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="31" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource Accent}"/>
                                <TextBlock Text="Mbps" FontSize="11" Foreground="{StaticResource TextSubtle}" VerticalAlignment="Bottom" Margin="0,0,0,3"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Spacing="1">
                            <TextBlock Text="↑ Upload" FontSize="11" Foreground="{StaticResource TextMuted}"/>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="12" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource Orange}"/>
                                <TextBlock Text="Mbps" FontSize="11" Foreground="{StaticResource TextSubtle}" VerticalAlignment="Bottom" Margin="0,0,0,3"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                    <controls:Sparkline Height="96" Stroke="{StaticResource Accent}"
                                        Points="0,60 5,48 10,66 15,38 20,58 25,30 30,50 35,26 40,44 45,56 50,32 55,52 60,22 65,46 70,34 75,58 80,28 85,44 90,54 95,32 100,42"/>
                </StackPanel>
            </Border>
        </Grid>
    </StackPanel>
</UserControl>
