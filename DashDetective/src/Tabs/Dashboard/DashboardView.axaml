<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="using:DashDetective.Shared.Controls"
             xmlns:vm="using:DashDetective.Tabs.Dashboard"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="920"
             x:DataType="vm:DashboardViewModel"
             x:Class="DashDetective.Tabs.Dashboard.DashboardView">

    <UserControl.Styles>
        <!-- Each stat card's accent brush is picked by its category class, keeping the dot + sparkline
             theme/accent-aware (as the fixed per-card bindings did before the row became collection-bound). -->
        <Style Selector="controls|StatCard.cpu"><Setter Property="Accent" Value="{DynamicResource ChartCpu}"/></Style>
        <Style Selector="controls|StatCard.mem"><Setter Property="Accent" Value="{DynamicResource ChartMemory}"/></Style>
        <Style Selector="controls|StatCard.gpu"><Setter Property="Accent" Value="{DynamicResource ChartGpu}"/></Style>
        <Style Selector="controls|StatCard.disk"><Setter Property="Accent" Value="{DynamicResource ChartStorage}"/></Style>
        <Style Selector="controls|StatCard.net"><Setter Property="Accent" Value="{DynamicResource ChartNetDown}"/></Style>
    </UserControl.Styles>

    <!-- Surfaces/typography come from src/Shared/Styles; StatCard / Sparkline / InfoRow come from
         src/Shared/Controls. -->
    <StackPanel Spacing="16">

        <!-- ===== Stat cards: one per detected device, up to five per row then wrapping, grouped by kind
             (CPUs → Memory → GPUs → Disks → Network). The -6/+6 margins keep the row flush at the edges. -->
        <ItemsControl ItemsSource="{Binding Cards}" Margin="-6">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="5"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:DashboardCard">
                    <controls:StatCard Margin="6"
                                       Classes.cpu="{Binding IsCpu}" Classes.mem="{Binding IsMemory}"
                                       Classes.gpu="{Binding IsGpu}" Classes.disk="{Binding IsDisk}"
                                       Classes.net="{Binding IsNetwork}"
                                       Label="{Binding Label}" Value="{Binding Value}" Unit="{Binding Unit}"
                                       Sub="{Binding Sub}" YMin="0" YMax="100" Points="{Binding Points}"/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- ===== Utilization charts ===== -->
        <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
            <Border Grid.Column="0" Classes="panel">
                <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Classes="panelTitle" Text="CPU Utilization"/>
                        <TextBlock Grid.Column="1" Text="{Binding CpuPercentText}" FontSize="12" Foreground="{DynamicResource ChartCpu}"/>
                    </Grid>
                    <controls:Sparkline Height="130" ShowGrid="True" Stroke="{DynamicResource ChartCpu}"
                                        YMin="0" YMax="100" Points="{Binding CpuPoints}"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Classes="panel">
                <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Classes="panelTitle" Text="Memory Utilization"/>
                        <TextBlock Grid.Column="1" Text="{Binding MemoryUtilizationText}" FontSize="12" Foreground="{DynamicResource ChartMemory}"/>
                    </Grid>
                    <controls:Sparkline Height="130" ShowGrid="True" Stroke="{DynamicResource ChartMemory}"
                                        YMin="0" YMax="100" Points="{Binding MemoryPoints}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===== System info + Network throughput ===== -->
        <Grid ColumnDefinitions="1.35*,*" ColumnSpacing="16">

            <Border Grid.Column="0" Classes="panel">
                <StackPanel Spacing="8">
                    <TextBlock Classes="panelTitle" Text="System Information"/>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="24">
                        <StackPanel Grid.Column="0">
                            <controls:InfoRow Key="OS" Value="{Binding OsText}"/>
                            <controls:InfoRow Key="Device" Value="{Binding DeviceText}"/>
                            <controls:InfoRow Key="Cores" Value="{Binding CpuCoresText}"/>
                            <controls:InfoRow Key="GPU" Value="{Binding GpuModelText}"/>
                            <controls:InfoRow Key="BIOS" Value="{Binding BiosText}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <controls:InfoRow Key="Build" Value="{Binding BuildText}"/>
                            <controls:InfoRow Key="CPU" Value="{Binding CpuModelText}"/>
                            <controls:InfoRow Key="RAM" Value="{Binding MemoryModelText}"/>
                            <controls:InfoRow Key="Uptime" Value="{Binding UptimeText}"/>
                            <controls:InfoRow Key="Motherboard" Value="{Binding MotherboardText}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Classes="panel">
                <StackPanel Spacing="12">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Classes="panelTitle" Text="Network Throughput"/>
                        <TextBlock Grid.Column="1" Text="{Binding NetworkAdapterName}" FontSize="11" Foreground="{DynamicResource TextSubtle}"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <StackPanel Spacing="1">
                            <TextBlock Text="↓ Download" FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="{Binding NetworkDownText}" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource ChartNetDown}"/>
                                <TextBlock Text="{Binding NetworkDownUnit}" FontSize="11" Foreground="{DynamicResource TextSubtle}" VerticalAlignment="Bottom" Margin="0,0,0,3"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Spacing="1">
                            <TextBlock Text="↑ Upload" FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="{Binding NetworkUpText}" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource ChartNetUp}"/>
                                <TextBlock Text="{Binding NetworkUpUnit}" FontSize="11" Foreground="{DynamicResource TextSubtle}" VerticalAlignment="Bottom" Margin="0,0,0,3"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                    <controls:Sparkline Height="96" Fill="True"
                                        Stroke="{DynamicResource ChartNetDown}" Points="{Binding NetworkDownPoints}"
                                        Stroke2="{DynamicResource ChartNetUp}" Points2="{Binding NetworkUpPoints}"
                                        YMin="0" YMax="100"/>
                </StackPanel>
            </Border>
        </Grid>
    </StackPanel>
</UserControl>
