<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:settings="using:DashDetective.Tabs.Settings"
             xmlns:nav="using:DashDetective.Shell.Navigation"
             mc:Ignorable="d" d:DesignWidth="760" d:DesignHeight="720"
             x:DataType="settings:SettingsViewModel"
             x:Class="DashDetective.Tabs.Settings.SettingsView">

    <!-- Appearance (Theme + Accent) is wired to SettingsViewModel via the ThemeService.
         Monitoring and Export & Data below are still static layout.
         Surfaces, segments, toggles and buttons are styled from src/Shared/Styles. -->
    <UserControl.Styles>
        <Style Selector="TextBlock.settingName">
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="TextBlock.settingDesc">
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSubtle}"/>
        </Style>

        <!-- Chrome-less button wrapper so a whole segment / swatch is clickable. -->
        <Style Selector="Button.pick">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.pick /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!-- Accent swatch + its selection ring. ClipToBounds so the four-colour legend of the
             default option is clipped to the rounded corners. -->
        <Style Selector="Border.swatch">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="ClipToBounds" Value="True"/>
        </Style>
        <Style Selector="Border.swatch.selected">
            <Setter Property="BorderBrush" Value="{DynamicResource TextStrong}"/>
        </Style>
    </UserControl.Styles>

    <StackPanel MaxWidth="720" HorizontalAlignment="Left" Spacing="16">

        <!-- ===== Appearance ===== -->
        <Border Classes="panel" Padding="18">
            <StackPanel Spacing="16">
                <TextBlock Classes="panelTitle" Text="Appearance"/>

                <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                    <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Classes="settingName" Text="Theme"/>
                        <TextBlock Classes="settingDesc" Text="Choose the application color scheme"/>
                    </StackPanel>
                    <Border Grid.Column="1" Classes="segments">
                        <ItemsControl ItemsSource="{Binding ThemeOptions}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="6"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="settings:ThemeOption">
                                    <Button Classes="pick" Command="{Binding SelectCommand}">
                                        <Border Classes="seg" Classes.selected="{Binding IsSelected}">
                                            <TextBlock Text="{Binding Label}"/>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </Grid>

                <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                    <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Classes="settingName" Text="Accent color"/>
                        <TextBlock Classes="settingDesc" Text="Applied to charts and highlights"/>
                    </StackPanel>
                    <ItemsControl Grid.Column="1" ItemsSource="{Binding AccentOptions}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="8"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="settings:AccentOption">
                                <Button Classes="pick" Command="{Binding SelectCommand}"
                                        ToolTip.Tip="{Binding Preset.Name, FallbackValue='Default'}">
                                    <Border Classes="swatch" Classes.selected="{Binding IsSelected}"
                                            Background="{Binding Swatch}">
                                        <!-- Four-colour legend, shown only for the Default option. -->
                                        <Grid IsVisible="{Binding IsDefault}"
                                              ColumnDefinitions="*,*" RowDefinitions="*,*">
                                            <Border Grid.Row="0" Grid.Column="0" Background="{StaticResource Blue}"/>
                                            <Border Grid.Row="0" Grid.Column="1" Background="{StaticResource Green}"/>
                                            <Border Grid.Row="1" Grid.Column="0" Background="{StaticResource Purple}"/>
                                            <Border Grid.Row="1" Grid.Column="1" Background="{StaticResource Orange}"/>
                                        </Grid>
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ===== Navigation ===== -->
        <!-- These controls drive the shared NavigationViewModel, so they stay in sync with the
             on-bar collapse chevron and orientation menu. -->
        <Border Classes="panel" Padding="18">
            <StackPanel Spacing="16">
                <TextBlock Classes="panelTitle" Text="Navigation"/>

                <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                    <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Classes="settingName" Text="Position"/>
                        <TextBlock Classes="settingDesc" Text="Which edge the navigation bar docks to"/>
                    </StackPanel>
                    <Border Grid.Column="1" Classes="segments">
                        <ItemsControl ItemsSource="{Binding Nav.Positions}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="6"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="nav:NavPositionOption">
                                    <Button Classes="pick" Command="{Binding SelectCommand}">
                                        <Border Classes="seg" Classes.selected="{Binding IsSelected}">
                                            <TextBlock Text="{Binding Label}"/>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </Grid>

                <Border BorderBrush="{DynamicResource RowLine}" BorderThickness="0,1,0,0" Padding="0,9,0,0">
                    <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Classes="settingName" Text="Collapse to icons"/>
                            <TextBlock Classes="settingDesc" Text="Show only the icons in the navigation bar"/>
                        </StackPanel>
                        <Border Grid.Column="1" Classes="segments">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Button Classes="pick" Command="{Binding Nav.ExpandCommand}">
                                    <Border Classes="seg" Classes.selected="{Binding !Nav.IsCollapsed}">
                                        <TextBlock Text="Expanded"/>
                                    </Border>
                                </Button>
                                <Button Classes="pick" Command="{Binding Nav.CollapseCommand}">
                                    <Border Classes="seg" Classes.selected="{Binding Nav.IsCollapsed}">
                                        <TextBlock Text="Icons only"/>
                                    </Border>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </StackPanel>
        </Border>

        <!-- ===== Monitoring ===== -->
        <Border Classes="panel" Padding="18">
            <StackPanel Spacing="16">
                <TextBlock Classes="panelTitle" Text="Monitoring"/>

                <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                    <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Classes="settingName" Text="Refresh interval"/>
                        <TextBlock Classes="settingDesc" Text="How often live metrics update"/>
                    </StackPanel>
                    <Border Grid.Column="1" Classes="segments">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Border Classes="seg"><TextBlock Text="0.5s"/></Border>
                            <Border Classes="seg selected"><TextBlock Text="1s"/></Border>
                            <Border Classes="seg"><TextBlock Text="2s"/></Border>
                            <Border Classes="seg"><TextBlock Text="5s"/></Border>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Toggle rows -->
                <Border BorderBrush="{DynamicResource RowLine}" BorderThickness="0,1,0,0" Padding="0,9,0,0">
                    <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Classes="settingName" Text="Desktop notifications"/>
                            <TextBlock Classes="settingDesc" Text="Alert on threshold breaches"/>
                        </StackPanel>
                        <Border Grid.Column="1" Classes="toggle" Background="{DynamicResource Accent}">
                            <Ellipse Width="16" Height="16" Fill="{DynamicResource TextStrong}" HorizontalAlignment="Right" Margin="0,0,3,0"/>
                        </Border>
                    </Grid>
                </Border>

                <Border BorderBrush="{DynamicResource RowLine}" BorderThickness="0,1,0,0" Padding="0,9,0,0">
                    <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Classes="settingName" Text="Resource alerts"/>
                            <TextBlock Classes="settingDesc" Text="Warn when CPU or RAM exceeds 90%"/>
                        </StackPanel>
                        <Border Grid.Column="1" Classes="toggle" Background="{DynamicResource TrackOff}">
                            <Ellipse Width="16" Height="16" Fill="{DynamicResource TextStrong}" HorizontalAlignment="Left" Margin="3,0,0,0"/>
                        </Border>
                    </Grid>
                </Border>

                <Border BorderBrush="{DynamicResource RowLine}" BorderThickness="0,1,0,0" Padding="0,9,0,0">
                    <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Classes="settingName" Text="Show in system tray"/>
                            <TextBlock Classes="settingDesc" Text="Keep console running in background"/>
                        </StackPanel>
                        <Border Grid.Column="1" Classes="toggle" Background="{DynamicResource Accent}">
                            <Ellipse Width="16" Height="16" Fill="{DynamicResource TextStrong}" HorizontalAlignment="Right" Margin="0,0,3,0"/>
                        </Border>
                    </Grid>
                </Border>

                <Border BorderBrush="{DynamicResource RowLine}" BorderThickness="0,1,0,0" Padding="0,9,0,0">
                    <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Classes="settingName" Text="Launch at startup"/>
                            <TextBlock Classes="settingDesc" Text="Start with Windows"/>
                        </StackPanel>
                        <Border Grid.Column="1" Classes="toggle" Background="{DynamicResource TrackOff}">
                            <Ellipse Width="16" Height="16" Fill="{DynamicResource TextStrong}" HorizontalAlignment="Left" Margin="3,0,0,0"/>
                        </Border>
                    </Grid>
                </Border>
            </StackPanel>
        </Border>

        <!-- ===== Export & Data ===== -->
        <Border Classes="panel" Padding="18">
            <StackPanel Spacing="14">
                <TextBlock Classes="panelTitle" Text="Export &amp; Data"/>
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button Classes="action primary" Content="Export report (PDF)"/>
                    <Button Classes="action" Content="Export CSV"/>
                    <Button Classes="action" Content="Copy diagnostics"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <TextBlock HorizontalAlignment="Center" FontSize="11.5" Foreground="{DynamicResource TextFaint}"
                   Text="System Information Console v3.2.1 · Build 24019 · © 2026"/>
    </StackPanel>
</UserControl>
