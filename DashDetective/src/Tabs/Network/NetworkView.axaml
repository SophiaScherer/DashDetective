<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="using:DashDetective.Shared.Controls"
             xmlns:vm="using:DashDetective.Tabs.Network"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="720"
             x:DataType="vm:NetworkViewModel"
             x:Class="DashDetective.Tabs.Network.NetworkView">

    <!-- The design comp's Network page: six panels in two rows (Adapters · IP Configuration ·
         Throughput / Active Connections · Ping · DNS Lookup). Surfaces/typography come from
         src/Shared/Styles; the throughput charts reuse the shared Sparkline. -->
    <!-- Monospace token is tab-local: no mono font is used elsewhere in the app yet. Promote to
         SharedStyles if a second feature needs it. Used for IP/address values that read better
         column-aligned (IP config, connection endpoints, ping/DNS console output). ConsoleBg is a
         fixed dark terminal surface (kept dark in BOTH themes) so the fixed green/blue console text
         stays readable — a light inset would wash it out. -->
    <UserControl.Resources>
        <FontFamily x:Key="MonoFont">Cascadia Mono,Consolas,Courier New,monospace</FontFamily>
        <SolidColorBrush x:Key="ConsoleBg" Color="#111318"/>
        <!-- Fixed console text colours (the surface is fixed-dark in both themes, so these can't
             follow the theme ramp or they'd vanish on the dark inset). -->
        <SolidColorBrush x:Key="ConsoleFg" Color="#c8ccd2"/>
        <SolidColorBrush x:Key="ConsoleMuted" Color="#8b9099"/>
        <SolidColorBrush x:Key="ConsoleGreen" Color="#6ccb5f"/>
        <SolidColorBrush x:Key="ConsoleBlue" Color="#4cc2ff"/>
    </UserControl.Resources>

    <UserControl.Styles>
        <!-- One IP Configuration key/value row: muted key on the left, monospace value on the right. -->
        <Style Selector="TextBlock.ipKey">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBlock.ipVal">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <!-- Uppercase muted column header for the connections table. -->
        <Style Selector="TextBlock.colHead">
            <Setter Property="FontSize" Value="10.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSubtle}"/>
        </Style>
        <!-- Compact editable field (Ping/DNS targets) + its submit button. This is the app's first
             bound text input; it mirrors the toolbar search field's surface tokens. -->
        <Style Selector="Border.field">
            <Setter Property="Background" Value="{DynamicResource FieldBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Hairline}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Height" Value="30"/>
        </Style>
        <Style Selector="Border.field TextBox">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="9,0"/>
        </Style>
        <Style Selector="Button.go">
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="{DynamicResource HoverOverlay}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.go:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource HoverOverlayStrong}"/>
        </Style>
        <!-- Google-style pager: page-number / arrow buttons, with the current page accented and
             ellipsis / end-arrows dimmed via the disabled state. -->
        <Style Selector="Button.pageLink">
            <Setter Property="MinWidth" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.pageLink:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource HoverOverlay}"/>
        </Style>
        <Style Selector="Button.pageLink.selected">
            <Setter Property="Background" Value="{DynamicResource Accent}"/>
            <Setter Property="Foreground" Value="{DynamicResource OnAccent}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </UserControl.Styles>

    <StackPanel Spacing="16">

        <!-- ===== Row 1: Adapters · IP Configuration · Throughput ===== -->
        <Grid ColumnDefinitions="*,*,1.1*" ColumnSpacing="16">
            <Border Grid.Column="0" Classes="panel">
                <StackPanel Spacing="8">
                    <TextBlock Classes="panelTitle" Text="Adapters"/>
                    <!-- Cap the list to ~the IP Configuration card's height and scroll the overflow, so
                         a machine with many adapters doesn't push the rest of the page off-screen. -->
                    <ScrollViewer MaxHeight="188"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Adapters}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:AdapterInfo">
                                    <!-- Right padding reserves a gutter so the vertical scrollbar sits
                                         beside the row content (link speed) rather than over it. -->
                                    <Border BorderBrush="{DynamicResource RowLine}"
                                            BorderThickness="0,0,0,1" Padding="0,9,14,9">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <Ellipse Grid.Column="0" Width="9" Height="9" VerticalAlignment="Center"
                                                     Fill="{Binding DotBrush}"/>
                                            <StackPanel Grid.Column="1" Margin="11,0,8,0" Spacing="1">
                                                <TextBlock Text="{Binding Name}" FontSize="12.5" FontWeight="Medium"
                                                           Foreground="{DynamicResource TextPrimary}" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Description}" FontSize="11"
                                                           Foreground="{DynamicResource TextSubtle}" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" Spacing="1" HorizontalAlignment="Right">
                                                <TextBlock Text="{Binding StatusText}" FontSize="11.5" TextAlignment="Right"
                                                           Foreground="{Binding StatusBrush}"/>
                                                <TextBlock Text="{Binding SpeedText}" FontSize="11" TextAlignment="Right"
                                                           Foreground="{DynamicResource TextSubtle}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Classes="panel">
                <StackPanel Spacing="12">
                    <TextBlock Classes="panelTitle" Text="IP Configuration"/>
                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="9">
                        <TextBlock Grid.Row="0" Grid.Column="0" Classes="ipKey" Text="IPv4 Address"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Classes="ipVal" Text="{Binding IpConfig.Ipv4}"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Classes="ipKey" Text="Subnet Mask"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Classes="ipVal" Text="{Binding IpConfig.SubnetMask}"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Classes="ipKey" Text="Gateway"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Classes="ipVal" Text="{Binding IpConfig.Gateway}"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Classes="ipKey" Text="DNS"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Classes="ipVal" Text="{Binding IpConfig.Dns}"/>
                        <TextBlock Grid.Row="4" Grid.Column="0" Classes="ipKey" Text="MAC"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Classes="ipVal" Text="{Binding IpConfig.Mac}"/>
                        <TextBlock Grid.Row="5" Grid.Column="0" Classes="ipKey" Text="DHCP"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" Classes="ipVal" Text="{Binding IpConfig.Dhcp}"/>
                    </Grid>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Classes="panel">
                <StackPanel Spacing="10">
                    <TextBlock Classes="panelTitle" Text="Throughput"/>
                    <!-- Both charts share one Y axis (ThroughputYMax), so their heights must match too:
                         equal Mbps must map to equal pixels for the comparison to be honest. The peak
                         caption on the right makes the shared ceiling legible. -->
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="18">
                            <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Bottom">
                                <TextBlock Text="↓" FontSize="12" Foreground="{DynamicResource ChartNetDown}"/>
                                <TextBlock Text="{Binding DownText}" FontSize="12" Foreground="{DynamicResource TextMuted}"/>
                                <TextBlock Text="{Binding DownUnit}" FontSize="12" Foreground="{DynamicResource TextSubtle}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Bottom">
                                <TextBlock Text="↑" FontSize="12" Foreground="{DynamicResource ChartNetUp}"/>
                                <TextBlock Text="{Binding UpText}" FontSize="12" Foreground="{DynamicResource TextMuted}"/>
                                <TextBlock Text="{Binding UpUnit}" FontSize="12" Foreground="{DynamicResource TextSubtle}"/>
                            </StackPanel>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="{Binding ThroughputScaleText}" FontSize="11"
                                   VerticalAlignment="Bottom" Foreground="{DynamicResource TextSubtle}"/>
                    </Grid>
                    <controls:Sparkline Height="65" Fill="True"
                                        Stroke="{DynamicResource ChartNetDown}" Points="{Binding DownPoints}"
                                        YMin="0" YMax="{Binding ThroughputYMax}"/>
                    <controls:Sparkline Height="65" Fill="True"
                                        Stroke="{DynamicResource ChartNetUp}" Points="{Binding UpPoints}"
                                        YMin="0" YMax="{Binding ThroughputYMax}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===== Row 2: Active Connections · (Ping + DNS) ===== -->
        <Grid ColumnDefinitions="1.6*,*" ColumnSpacing="16">
            <Border Grid.Column="0" Classes="panel">
                <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Classes="panelTitle" Text="Active Connections"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding ConnectionsSummary}" FontSize="11"
                                   VerticalAlignment="Center" Foreground="{DynamicResource TextSubtle}"/>
                    </Grid>
                    <!-- Column header. The 14px right margin matches the rows' gutter below so the columns
                         stay aligned and the scrollbar sits in the shared gutter, not over the text. -->
                    <Grid ColumnDefinitions="1.2*,1.4*,*,Auto" Margin="0,0,14,2">
                        <TextBlock Grid.Column="0" Classes="colHead" Text="PROCESS"/>
                        <TextBlock Grid.Column="1" Classes="colHead" Text="REMOTE ADDRESS"/>
                        <TextBlock Grid.Column="2" Classes="colHead" Text="STATE"/>
                        <TextBlock Grid.Column="3" Classes="colHead" Text="PROTOCOL" TextAlignment="Right"/>
                    </Grid>
                    <!-- Whole page scrolls, so bound the table's own scroller or it never engages. Kept
                         compact enough that the panel + pager stay on-screen in the default (non-maximized)
                         window rather than pushing the pager below the fold. -->
                    <ScrollViewer x:Name="ConnectionsScroller" MaxHeight="240"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Connections}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ConnectionRow">
                                    <Grid ColumnDefinitions="1.2*,1.4*,*,Auto" Height="30" Margin="0,0,14,0">
                                        <TextBlock Grid.Column="0" Text="{Binding Process}" FontSize="12"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                   Foreground="{DynamicResource TextPrimary}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding RemoteEndpoint}" FontSize="11.5"
                                                   FontFamily="{StaticResource MonoFont}" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextSubtle}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding State}" FontSize="11.5"
                                                   VerticalAlignment="Center" Foreground="{Binding StateBrush}"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Protocol}" FontSize="11.5"
                                                   VerticalAlignment="Center" TextAlignment="Right"
                                                   Foreground="{DynamicResource TextMuted}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <!-- Pager (Prev · 1 … 4 5 6 … 20 · Next); only visible when there's >1 page. -->
                    <ItemsControl ItemsSource="{Binding PageLinks}" IsVisible="{Binding PagerVisible}"
                                  HorizontalAlignment="Center" Margin="0,2,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="4"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:PageLink">
                                <Button Classes="pageLink" Classes.selected="{Binding IsCurrent}"
                                        Content="{Binding Label}" Command="{Binding SelectCommand}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
            <StackPanel Grid.Column="1" Spacing="12">
                <Border Classes="panel">
                    <StackPanel Spacing="10">
                        <TextBlock Classes="panelTitle" Text="Ping"/>
                        <!-- Editable target: Enter or the button applies it (resets the rolling stats). -->
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                            <Border Grid.Column="0" Classes="field">
                                <TextBox Text="{Binding PingTarget, Mode=TwoWay}"
                                         PlaceholderText="Host or IP to ping">
                                    <TextBox.KeyBindings>
                                        <KeyBinding Gesture="Enter" Command="{Binding ApplyPingTargetCommand}"/>
                                    </TextBox.KeyBindings>
                                </TextBox>
                            </Border>
                            <Button Grid.Column="1" Classes="go" Content="Ping"
                                    Command="{Binding ApplyPingTargetCommand}"/>
                        </Grid>
                        <Border Background="{StaticResource ConsoleBg}" CornerRadius="6" Padding="10">
                            <StackPanel Spacing="3">
                                <TextBlock Text="{Binding PingConsole}" FontFamily="{StaticResource MonoFont}"
                                           FontSize="11" Foreground="{StaticResource ConsoleGreen}" TextWrapping="NoWrap"/>
                                <TextBlock Text="{Binding PingSummary}" FontFamily="{StaticResource MonoFont}"
                                           FontSize="11" Foreground="{StaticResource ConsoleMuted}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
                <Border Classes="panel">
                    <StackPanel Spacing="10">
                        <TextBlock Classes="panelTitle" Text="DNS Lookup"/>
                        <!-- Editable host: Enter or the button re-resolves it. -->
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                            <Border Grid.Column="0" Classes="field">
                                <TextBox Text="{Binding DnsHost, Mode=TwoWay}"
                                         PlaceholderText="Host name to resolve">
                                    <TextBox.KeyBindings>
                                        <KeyBinding Gesture="Enter" Command="{Binding LookupDnsCommand}"/>
                                    </TextBox.KeyBindings>
                                </TextBox>
                            </Border>
                            <Button Grid.Column="1" Classes="go" Content="Look up"
                                    Command="{Binding LookupDnsCommand}"/>
                        </Grid>
                        <Border Background="{StaticResource ConsoleBg}" CornerRadius="6" Padding="10">
                            <StackPanel Spacing="3">
                                <TextBlock Text="{Binding DnsConsole}" FontFamily="{StaticResource MonoFont}"
                                           FontSize="11" Foreground="{StaticResource ConsoleFg}" TextWrapping="NoWrap"/>
                                <TextBlock Text="{Binding DnsFooter}" FontFamily="{StaticResource MonoFont}"
                                           FontSize="11" Foreground="{StaticResource ConsoleBlue}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </StackPanel>
</UserControl>
