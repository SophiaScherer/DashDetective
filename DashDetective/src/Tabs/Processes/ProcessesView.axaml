<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:DashDetective.Tabs.Processes"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="720"
             x:DataType="vm:ProcessesViewModel"
             x:Class="DashDetective.Tabs.Processes.ProcessesView">

    <!-- Live process table, split into Apps and Background groups. Self-scrolling: the header stays
         fixed while the grouped list scrolls. Surfaces/typography come from src/Shared/Styles.
         The shared 8-column layout is repeated on the header and each row (like the Network and File
         Explorer tables). Disk/GPU arrive in a later phase; Network is deferred, so those cells show "—". -->
    <UserControl.Styles>
        <!-- Column header cells. -->
        <Style Selector="TextBlock.colHead">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
        </Style>
        <Style Selector="TextBlock.colHead.num">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="TextAlignment" Value="Right"/>
        </Style>

        <!-- Group section header (e.g. "Apps · 6"). -->
        <Style Selector="Border.groupHead">
            <Setter Property="Background" Value="{DynamicResource HoverOverlay}"/>
            <Setter Property="Padding" Value="16,7"/>
        </Style>
        <Style Selector="Border.groupHead TextBlock">
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
        </Style>

        <!-- Data rows. -->
        <Style Selector="Border.procRow">
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderBrush" Value="{DynamicResource RowLine}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Border.procRow:pointerover">
            <Setter Property="Background" Value="{DynamicResource HoverOverlay}"/>
        </Style>
        <Style Selector="Border.procRow TextBlock">
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBlock.cellName">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
        <Style Selector="TextBlock.cellPid">
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
        </Style>
        <!-- Numeric cells: right-aligned, themed text. -->
        <Style Selector="TextBlock.cellNum">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="TextAlignment" Value="Right"/>
        </Style>
        <!-- CPU cell: themed by default, tinted amber/orange when elevated (classes from ProcessRow). -->
        <Style Selector="TextBlock.cpuCell">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="TextAlignment" Value="Right"/>
        </Style>
        <Style Selector="TextBlock.cpuCell.med">
            <Setter Property="Foreground" Value="#ffcf4d"/>
        </Style>
        <Style Selector="TextBlock.cpuCell.high">
            <Setter Property="Foreground" Value="#ff8a5c"/>
        </Style>
    </UserControl.Styles>

    <Border Classes="panel" Padding="0" ClipToBounds="True">
        <Grid RowDefinitions="Auto,*">

            <!-- Sticky column header -->
            <Border Grid.Row="0" Padding="16,11" BorderBrush="{DynamicResource Hairline}"
                    BorderThickness="0,0,0,1" Background="{DynamicResource CardBackground}">
                <Grid ColumnDefinitions="2.4*,0.7*,1*,0.85*,0.85*,0.85*,0.85*,0.85*" ColumnSpacing="4">
                    <TextBlock Grid.Column="0" Classes="colHead" Text="NAME"/>
                    <TextBlock Grid.Column="1" Classes="colHead" Text="PID"/>
                    <TextBlock Grid.Column="2" Classes="colHead" Text="STATUS"/>
                    <TextBlock Grid.Column="3" Classes="colHead num" Text="CPU"/>
                    <TextBlock Grid.Column="4" Classes="colHead num" Text="MEMORY"/>
                    <TextBlock Grid.Column="5" Classes="colHead num" Text="DISK"/>
                    <TextBlock Grid.Column="6" Classes="colHead num" Text="NET"/>
                    <TextBlock Grid.Column="7" Classes="colHead num" Text="GPU"/>
                </Grid>
            </Border>

            <!-- Scrolling grouped list -->
            <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Apps -->
                    <Border Classes="groupHead">
                        <TextBlock Text="{Binding AppsHeader}"/>
                    </Border>
                    <ItemsControl ItemsSource="{Binding Apps}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ProcessRow">
                                <Border Classes="procRow" Background="Transparent">
                                    <Grid ColumnDefinitions="2.4*,0.7*,1*,0.85*,0.85*,0.85*,0.85*,0.85*"
                                          ColumnSpacing="4">
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="9">
                                            <Ellipse Width="7" Height="7" VerticalAlignment="Center"
                                                     Fill="{Binding StatusBrush}"/>
                                            <TextBlock Classes="cellName" Text="{Binding Name}"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Classes="cellPid" Text="{Binding PidText}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Status}" FontSize="11.5"
                                                   Foreground="{Binding StatusBrush}"/>
                                        <TextBlock Grid.Column="3" Classes="cpuCell"
                                                   Classes.high="{Binding CpuHigh}" Classes.med="{Binding CpuMed}"
                                                   Text="{Binding CpuText}"/>
                                        <TextBlock Grid.Column="4" Classes="cellNum" Text="{Binding MemoryText}"/>
                                        <TextBlock Grid.Column="5" Classes="cellNum" Text="{Binding DiskText}"/>
                                        <TextBlock Grid.Column="6" Classes="cellNum" Text="{Binding NetworkText}"/>
                                        <TextBlock Grid.Column="7" Classes="cellNum" Text="{Binding GpuText}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Background -->
                    <Border Classes="groupHead">
                        <TextBlock Text="{Binding BackgroundHeader}"/>
                    </Border>
                    <ItemsControl ItemsSource="{Binding Background}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ProcessRow">
                                <Border Classes="procRow" Background="Transparent">
                                    <Grid ColumnDefinitions="2.4*,0.7*,1*,0.85*,0.85*,0.85*,0.85*,0.85*"
                                          ColumnSpacing="4">
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="9">
                                            <Ellipse Width="7" Height="7" VerticalAlignment="Center"
                                                     Fill="{Binding StatusBrush}"/>
                                            <TextBlock Classes="cellName" Text="{Binding Name}"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Classes="cellPid" Text="{Binding PidText}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Status}" FontSize="11.5"
                                                   Foreground="{Binding StatusBrush}"/>
                                        <TextBlock Grid.Column="3" Classes="cpuCell"
                                                   Classes.high="{Binding CpuHigh}" Classes.med="{Binding CpuMed}"
                                                   Text="{Binding CpuText}"/>
                                        <TextBlock Grid.Column="4" Classes="cellNum" Text="{Binding MemoryText}"/>
                                        <TextBlock Grid.Column="5" Classes="cellNum" Text="{Binding DiskText}"/>
                                        <TextBlock Grid.Column="6" Classes="cellNum" Text="{Binding NetworkText}"/>
                                        <TextBlock Grid.Column="7" Classes="cellNum" Text="{Binding GpuText}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
