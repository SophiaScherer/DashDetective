<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="920"
             x:Class="DashDetective.Dashboard.DashboardView">

    <UserControl.Resources>
        <SolidColorBrush x:Key="PanelBg" Color="#1c1c1c"/>
        <SolidColorBrush x:Key="CardBg" Color="#212121"/>
        <SolidColorBrush x:Key="Hairline" Color="#FFFFFF" Opacity="0.06"/>
        <SolidColorBrush x:Key="RowLine" Color="#FFFFFF" Opacity="0.05"/>
        <SolidColorBrush x:Key="Label" Color="#FFFFFF" Opacity="0.5"/>
        <SolidColorBrush x:Key="Value" Color="#FFFFFF" Opacity="0.9"/>
        <SolidColorBrush x:Key="Sub" Color="#FFFFFF" Opacity="0.42"/>
        <SolidColorBrush x:Key="Accent" Color="#4cc2ff"/>
        <SolidColorBrush x:Key="Purple" Color="#c58fff"/>
    </UserControl.Resources>

    <UserControl.Styles>
        <!-- Stat card shell -->
        <Style Selector="Border.card">
            <Setter Property="Background" Value="{StaticResource CardBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Hairline}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="9"/>
            <Setter Property="Padding" Value="13,12"/>
        </Style>
        <!-- Larger panel shell -->
        <Style Selector="Border.panel">
            <Setter Property="Background" Value="{StaticResource PanelBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Hairline}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="9"/>
            <Setter Property="Padding" Value="16"/>
        </Style>
        <Style Selector="TextBlock.cardLabel">
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{StaticResource Label}"/>
        </Style>
        <Style Selector="TextBlock.cardValue">
            <Setter Property="FontSize" Value="26"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource Value}"/>
        </Style>
        <Style Selector="TextBlock.cardUnit">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource Label}"/>
        </Style>
        <Style Selector="TextBlock.cardSub">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource Sub}"/>
        </Style>
        <Style Selector="TextBlock.panelTitle">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <!-- System information key/value rows -->
        <Style Selector="Border.infoRow">
            <Setter Property="BorderBrush" Value="{StaticResource RowLine}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="0,7"/>
        </Style>
        <Style Selector="Border.infoRow TextBlock.infoKey">
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Foreground" Value="{StaticResource Label}"/>
        </Style>
        <Style Selector="Border.infoRow TextBlock.infoVal">
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{StaticResource Value}"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="TextAlignment" Value="Right"/>
        </Style>
    </UserControl.Styles>

    <StackPanel Spacing="16">

        <!-- ===== Stat cards ===== -->
        <Grid ColumnDefinitions="*,*,*,*,*" ColumnSpacing="12">

            <!-- CPU -->
            <Border Grid.Column="0" Classes="card">
                <StackPanel Spacing="6">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Classes="cardLabel" Text="CPU"/>
                        <Rectangle Grid.Column="1" Width="8" Height="8" RadiusX="2" RadiusY="2" Fill="#4cc2ff"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Classes="cardValue" Text="23"/>
                        <TextBlock Classes="cardUnit" Text="%" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                    </StackPanel>
                    <TextBlock Classes="cardSub" Text="Intel Core i9-14900K"/>
                    <Viewbox Height="34" Stretch="Fill" HorizontalAlignment="Stretch">
                        <Polyline Stroke="#4cc2ff" StrokeThickness="1.4" StrokeLineCap="Round" StrokeJoin="Round"
                                  Points="0,22 5,18 10,24 15,14 20,20 25,10 30,17 35,9 40,15 45,7 50,13 55,19 60,11 65,17 70,8 75,14 80,6 85,12 90,17 95,9 100,13"/>
                    </Viewbox>
                </StackPanel>
            </Border>

            <!-- Memory -->
            <Border Grid.Column="1" Classes="card">
                <StackPanel Spacing="6">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Classes="cardLabel" Text="MEMORY"/>
                        <Rectangle Grid.Column="1" Width="8" Height="8" RadiusX="2" RadiusY="2" Fill="#c58fff"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Classes="cardValue" Text="17.2"/>
                        <TextBlock Classes="cardUnit" Text="GB" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                    </StackPanel>
                    <TextBlock Classes="cardSub" Text="54% of 32 GB"/>
                    <Viewbox Height="34" Stretch="Fill" HorizontalAlignment="Stretch">
                        <Polyline Stroke="#c58fff" StrokeThickness="1.4" StrokeLineCap="Round" StrokeJoin="Round"
                                  Points="0,14 5,13 10,15 15,12 20,14 25,11 30,13 35,10 40,12 45,9 50,11 55,13 60,10 65,12 70,9 75,11 80,8 85,10 90,12 95,9 100,11"/>
                    </Viewbox>
                </StackPanel>
            </Border>

            <!-- GPU -->
            <Border Grid.Column="2" Classes="card">
                <StackPanel Spacing="6">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Classes="cardLabel" Text="GPU"/>
                        <Rectangle Grid.Column="1" Width="8" Height="8" RadiusX="2" RadiusY="2" Fill="#6ccb5f"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Classes="cardValue" Text="38"/>
                        <TextBlock Classes="cardUnit" Text="%" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                    </StackPanel>
                    <TextBlock Classes="cardSub" Text="RTX 4080 · 52°C"/>
                    <Viewbox Height="34" Stretch="Fill" HorizontalAlignment="Stretch">
                        <Polyline Stroke="#6ccb5f" StrokeThickness="1.4" StrokeLineCap="Round" StrokeJoin="Round"
                                  Points="0,18 5,16 10,19 15,13 20,17 25,12 30,15 35,10 40,14 45,11 50,13 55,16 60,12 65,15 70,10 75,13 80,9 85,12 90,15 95,11 100,13"/>
                    </Viewbox>
                </StackPanel>
            </Border>

            <!-- Storage -->
            <Border Grid.Column="3" Classes="card">
                <StackPanel Spacing="6">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Classes="cardLabel" Text="STORAGE"/>
                        <Rectangle Grid.Column="1" Width="8" Height="8" RadiusX="2" RadiusY="2" Fill="#ffcf4d"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Classes="cardValue" Text="68"/>
                        <TextBlock Classes="cardUnit" Text="%" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                    </StackPanel>
                    <TextBlock Classes="cardSub" Text="1.36 / 2.0 TB"/>
                    <Viewbox Height="34" Stretch="Fill" HorizontalAlignment="Stretch">
                        <Polyline Stroke="#ffcf4d" StrokeThickness="1.4" StrokeLineCap="Round" StrokeJoin="Round"
                                  Points="0,15 5,15 10,14 15,15 20,14 25,15 30,14 35,15 40,14 45,15 50,14 55,15 60,14 65,15 70,14 75,15 80,14 85,15 90,14 95,15 100,14"/>
                    </Viewbox>
                </StackPanel>
            </Border>

            <!-- Network -->
            <Border Grid.Column="4" Classes="card">
                <StackPanel Spacing="6">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Classes="cardLabel" Text="NETWORK"/>
                        <Rectangle Grid.Column="1" Width="8" Height="8" RadiusX="2" RadiusY="2" Fill="#4cc2ff"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Classes="cardValue" Text="31"/>
                        <TextBlock Classes="cardUnit" Text="Mbps" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                    </StackPanel>
                    <TextBlock Classes="cardSub" Text="↑ 12 Mbps"/>
                    <Viewbox Height="34" Stretch="Fill" HorizontalAlignment="Stretch">
                        <Polyline Stroke="#4cc2ff" StrokeThickness="1.4" StrokeLineCap="Round" StrokeJoin="Round"
                                  Points="0,20 5,15 10,23 15,12 20,19 25,9 30,16 35,7 40,14 45,18 50,10 55,17 60,6 65,15 70,11 75,19 80,8 85,14 90,17 95,10 100,13"/>
                    </Viewbox>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===== Utilization charts ===== -->
        <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
            <Border Grid.Column="0" Classes="panel">
                <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Classes="panelTitle" Text="CPU Utilization"/>
                        <TextBlock Grid.Column="1" Text="23%" FontSize="12" Foreground="{StaticResource Accent}"/>
                    </Grid>
                    <Border Height="130" CornerRadius="4" ClipToBounds="True">
                        <Viewbox Stretch="Fill">
                            <Polyline Stroke="#4cc2ff" StrokeThickness="1.6" StrokeLineCap="Round" StrokeJoin="Round"
                                      Points="0,70 4,66 8,72 12,55 16,63 20,40 24,58 28,35 32,52 36,28 40,46 44,60 48,38 52,54 56,30 60,48 64,26 68,44 72,58 76,34 80,50 84,24 88,42 92,56 96,32 100,46"/>
                        </Viewbox>
                    </Border>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Classes="panel">
                <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Classes="panelTitle" Text="Memory Utilization"/>
                        <TextBlock Grid.Column="1" Text="17.2 / 32 GB" FontSize="12" Foreground="{StaticResource Purple}"/>
                    </Grid>
                    <Border Height="130" CornerRadius="4" ClipToBounds="True">
                        <Viewbox Stretch="Fill">
                            <Polyline Stroke="#c58fff" StrokeThickness="1.6" StrokeLineCap="Round" StrokeJoin="Round"
                                      Points="0,48 4,46 8,50 12,44 16,47 20,42 24,45 28,40 32,44 36,38 40,42 44,46 48,40 52,44 56,39 60,43 64,37 68,41 72,45 76,39 80,43 84,36 88,40 92,44 96,38 100,42"/>
                        </Viewbox>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===== System info + Network throughput ===== -->
        <Grid ColumnDefinitions="1.35*,*" ColumnSpacing="16">

            <!-- System Information -->
            <Border Grid.Column="0" Classes="panel">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Classes="panelTitle" Text="System Information"/>
                        <TextBlock Grid.Column="1" Text="Updated 2 min ago" FontSize="11" Foreground="{StaticResource Sub}"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="24">
                        <StackPanel Grid.Column="0">
                            <Border Classes="infoRow">
                                <Grid ColumnDefinitions="Auto,*">
                                    <TextBlock Grid.Column="0" Classes="infoKey" Text="OS"/>
                                    <TextBlock Grid.Column="1" Classes="infoVal" Text="Windows 11 Pro 24H2"/>
                                </Grid>
                            </Border>
                            <Border Classes="infoRow">
                                <Grid ColumnDefinitions="Auto,*">
                                    <TextBlock Grid.Column="0" Classes="infoKey" Text="Device"/>
                                    <TextBlock Grid.Column="1" Classes="infoVal" Text="WORKSTATION-A9"/>
                                </Grid>
                            </Border>
                            <Border Classes="infoRow">
                                <Grid ColumnDefinitions="Auto,*">
                                    <TextBlock Grid.Column="0" Classes="infoKey" Text="Cores"/>
                                    <TextBlock Grid.Column="1" Classes="infoVal" Text="24 (8P + 16E)"/>
                                </Grid>
                            </Border>
                            <Border Classes="infoRow">
                                <Grid ColumnDefinitions="Auto,*">
                                    <TextBlock Grid.Column="0" Classes="infoKey" Text="GPU"/>
                                    <TextBlock Grid.Column="1" Classes="infoVal" Text="GeForce RTX 4080"/>
                                </Grid>
                            </Border>
                            <Border Classes="infoRow">
                                <Grid ColumnDefinitions="Auto,*">
                                    <TextBlock Grid.Column="0" Classes="infoKey" Text="BIOS"/>
                                    <TextBlock Grid.Column="1" Classes="infoVal" Text="AMI F31d"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <Border Classes="infoRow">
                                <Grid ColumnDefinitions="Auto,*">
                                    <TextBlock Grid.Column="0" Classes="infoKey" Text="Build"/>
                                    <TextBlock Grid.Column="1" Classes="infoVal" Text="26100.1150"/>
                                </Grid>
                            </Border>
                            <Border Classes="infoRow">
                                <Grid ColumnDefinitions="Auto,*">
                                    <TextBlock Grid.Column="0" Classes="infoKey" Text="CPU"/>
                                    <TextBlock Grid.Column="1" Classes="infoVal" Text="i9-14900K @ 3.2GHz"/>
                                </Grid>
                            </Border>
                            <Border Classes="infoRow">
                                <Grid ColumnDefinitions="Auto,*">
                                    <TextBlock Grid.Column="0" Classes="infoKey" Text="RAM"/>
                                    <TextBlock Grid.Column="1" Classes="infoVal" Text="32 GB DDR5-6000"/>
                                </Grid>
                            </Border>
                            <Border Classes="infoRow">
                                <Grid ColumnDefinitions="Auto,*">
                                    <TextBlock Grid.Column="0" Classes="infoKey" Text="Uptime"/>
                                    <TextBlock Grid.Column="1" Classes="infoVal" Text="3d 14h 22m"/>
                                </Grid>
                            </Border>
                            <Border Classes="infoRow">
                                <Grid ColumnDefinitions="Auto,*">
                                    <TextBlock Grid.Column="0" Classes="infoKey" Text="Motherboard"/>
                                    <TextBlock Grid.Column="1" Classes="infoVal" Text="ROG Z790-E"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Network Throughput -->
            <Border Grid.Column="1" Classes="panel">
                <StackPanel Spacing="12">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Classes="panelTitle" Text="Network Throughput"/>
                        <TextBlock Grid.Column="1" Text="Ethernet" FontSize="11" Foreground="{StaticResource Sub}"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <StackPanel Spacing="1">
                            <TextBlock Text="↓ Download" FontSize="11" Foreground="{StaticResource Label}"/>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="31" FontSize="18" FontWeight="SemiBold" Foreground="#4cc2ff"/>
                                <TextBlock Text="Mbps" FontSize="11" Foreground="{StaticResource Sub}" VerticalAlignment="Bottom" Margin="0,0,0,3"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Spacing="1">
                            <TextBlock Text="↑ Upload" FontSize="11" Foreground="{StaticResource Label}"/>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="12" FontSize="18" FontWeight="SemiBold" Foreground="#ff8a5c"/>
                                <TextBlock Text="Mbps" FontSize="11" Foreground="{StaticResource Sub}" VerticalAlignment="Bottom" Margin="0,0,0,3"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                    <Border Height="96" CornerRadius="4" ClipToBounds="True">
                        <Viewbox Stretch="Fill">
                            <Polyline Stroke="#4cc2ff" StrokeThickness="1.6" StrokeLineCap="Round" StrokeJoin="Round"
                                      Points="0,60 5,48 10,66 15,38 20,58 25,30 30,50 35,26 40,44 45,56 50,32 55,52 60,22 65,46 70,34 75,58 80,28 85,44 90,54 95,32 100,42"/>
                        </Viewbox>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </StackPanel>
</UserControl>
