<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="DashDetective.App"
             xmlns:shell="using:DashDetective.Shell"
             RequestedThemeVariant="Dark">
             <!-- Default is "Dark" (matches the design comp). ThemeService flips this to
                  "Light" or "Default" (follow system) when the user changes the Theme setting. -->

    <Application.DataTemplates>
        <shell:ViewLocator/>
    </Application.DataTemplates>

    <!-- System tray icon. Present whenever the app runs; the "Show in system tray" setting only
         governs whether closing the window hides here (MainWindow.OnClosing) or exits. Show/Exit are
         handled in App.axaml.cs, which holds the window reference. -->
    <TrayIcon.Icons>
        <TrayIcons>
            <TrayIcon Icon="/Assets/avalonia-logo.ico" ToolTipText="DashDetective" Clicked="OnTrayShow">
                <TrayIcon.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="Show DashDetective" Click="OnTrayShow"/>
                        <NativeMenuItem Header="Exit" Click="OnTrayExit"/>
                    </NativeMenu>
                </TrayIcon.Menu>
            </TrayIcon>
        </TrayIcons>
    </TrayIcon.Icons>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://DashDetective/src/Shared/Styles/Palette.axaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://DashDetective/src/Shared/Styles/SharedStyles.axaml"/>
    </Application.Styles>
</Application>