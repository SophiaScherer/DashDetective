<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="DashDetective.App"
             xmlns:shell="using:DashDetective.Shell"
             RequestedThemeVariant="Dark">
             <!-- Default is "Dark" (matches the design comp). ThemeService flips this to
                  "Light" or "Default" (follow system) when the user changes the Theme setting. -->

    <Application.DataTemplates>
        <shell:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://DashDetective/src/Shared/Styles/Palette.axaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://DashDetective/src/Shared/Styles/SharedStyles.axaml"/>
    </Application.Styles>
</Application>